# ===========================================================================
#   AutoStream AI Infinity — Environment Configuration
#   Copy this file to .env and fill in your values before starting.
#   Run `python scripts/generate_keys.py` to auto-generate secure keys.
# ===========================================================================


# ---------------------------------------------------------------------------
# 🗄️  DATABASE (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_USER=autostream
POSTGRES_PASSWORD=supersecretpassword        # ← Change this!
POSTGRES_DB=autostream_db
DATABASE_URL=postgresql+asyncpg://autostream:supersecretpassword@db:5432/autostream_db
#  For local development (without Docker), change @db to @localhost:
#  DATABASE_URL=postgresql+asyncpg://autostream:supersecretpassword@localhost:5432/autostream_db


# ---------------------------------------------------------------------------
# 🟥  REDIS & CELERY
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0            # General app cache / pub-sub
CELERY_BROKER_URL=redis://redis:6379/1    # Celery task broker
CELERY_RESULT_BACKEND=redis://redis:6379/2 # Celery result storage
#  For local development:
#  REDIS_URL=redis://localhost:6379/0


# ---------------------------------------------------------------------------
# 🔐  SECURITY & ENCRYPTION
# ---------------------------------------------------------------------------
# Fernet symmetric key — used to encrypt/decrypt all OAuth tokens in the DB.
# Generate with:  python scripts/generate_keys.py
FERNET_KEY=your_fernet_key_here

# JWT secret — used to sign internal API tokens (if you add auth middleware).
# Generate with:  openssl rand -hex 32
SECRET_KEY=your_long_random_jwt_secret_key_here


# ---------------------------------------------------------------------------
# 🤖  GOOGLE GEMINI AI
# ---------------------------------------------------------------------------
# Used for video frame analysis to generate viral titles, descriptions & hashtags.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Which Gemini model to use (text+vision). Keep default if unsure.
GEMINI_MODEL=gemini-2.0-flash


# ---------------------------------------------------------------------------
# 📺  GOOGLE OAUTH (YouTube + Google Drive)
# ---------------------------------------------------------------------------
# Create a project at: https://console.cloud.google.com/
# Enable: YouTube Data API v3, Google Drive API
# Create OAuth 2.0 credentials (Web Application type):
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/accounts/oauth/google/callback
# Note: For production, change localhost to your domain.

# API Vault JSONs (Google Cloud service account / OAuth project JSONs)
# are uploaded via the dashboard drag-and-drop UI and stored in the DB.
# No env variable needed for those — they live in the `api_key_vault` table.


# ---------------------------------------------------------------------------
# 📘  META (Facebook & Instagram)
# ---------------------------------------------------------------------------
# Create a Meta App at: https://developers.facebook.com/
# Enable: pages_manage_posts, instagram_content_publish, public_profile
META_CLIENT_ID=your_meta_app_id
META_CLIENT_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:8000/api/v1/accounts/oauth/meta/callback
META_WEBHOOK_VERIFY_TOKEN=your_meta_webhook_verify_token
# Scopes requested during Meta OAuth. Start minimal to avoid "Invalid Scopes" errors.
# After enabling/reviewing permissions in Meta console, you can extend this list.
META_SCOPES=public_profile,pages_show_list


# ---------------------------------------------------------------------------
# 📬  TELEGRAM BOT ALERTS
# ---------------------------------------------------------------------------
# 1. Message @BotFather on Telegram → /newbot → copy the token below.
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat_id.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ---------------------------------------------------------------------------
# 🌐  APPLICATION
# ---------------------------------------------------------------------------
APP_NAME="AutoStream AI Infinity"
DEBUG=false                             # Set to true for local development
# Comma-separated list of allowed frontend origins (JSON array string):
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Path to your watermark/logo PNG file (inside the container):
WATERMARK_PATH=/app/assets/watermark.png

# ---------------------------------------------------------------------------
# 🧹  POST-PUBLISH BEHAVIOR
# ---------------------------------------------------------------------------
# If true, delete the original source video from Google Drive after a successful publish.
# NOTE: This requires Google OAuth to include Drive scope, so you may need to reconnect Google.
DELETE_SOURCE_DRIVE_FILE_AFTER_PUBLISH=false
